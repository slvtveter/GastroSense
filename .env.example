# ==========================================
# GastroSense - Environment Variables Template
# ==========================================

# --- MySQL Database Configuration ---
MYSQL_DATABASE=restaurant_analytics
MYSQL_ROOT_PASSWORD=root_password
MYSQL_USER=analytics_user
MYSQL_PASSWORD=analytics_password

# --- FastAPI Backend Configuration ---
# Set host to 'db' when running within docker-compose, or 'localhost' if running FastAPI locally
DATABASE_URL=mysql+pymysql://analytics_user:analytics_password@db/restaurant_analytics
ENV=dev

# --- Streamlit Dashboard Configuration ---
# URL of the backend API service (uses Docker network alias 'backend' inside docker-compose)
BACKEND_API_URL=http://backend:8000/api/v1

# --- Portfolio & Contact Information (Render / Dev Env) ---
CONTACT_NAME="Илья Сергеев"
CONTACT_TELEGRAM="@asyncslvt"
CONTACT_EMAIL="ilya141005@gmail.com"
CONTACT_PHONE="+79153885443"
DEMO_URL=""

